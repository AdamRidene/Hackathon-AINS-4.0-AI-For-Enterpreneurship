# Firasa Frontend — Development Dockerfile
# Vite dev server with hot module reload
FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ .

EXPOSE 5173

# Vite dev server bound to 0.0.0.0 so Docker can reach it
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
