# ── Firasa Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Auth mode ────────────────────────────────────────────────────────────────
# local (default) = custom PBKDF2 + session tokens (zero-dependency dev)
# supabase         = validate Supabase Auth JWTs (production)
FIRASA_AUTH_MODE=local

# ── Supabase Auth (required when FIRASA_AUTH_MODE=supabase) ───────────────────
# Get these from Supabase Dashboard → Project Settings → API
FIRASA_SUPABASE_URL=https://your-project.supabase.co
FIRASA_SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
FIRASA_SUPABASE_ANON_KEY=your-anon-key

# ── Database ──────────────────────────────────────────────────────────────────
# Neon serverless PostgreSQL (required — no SQLite fallback).
# Create a free database at https://neon.tech and paste your connection string:
DATABASE_URL=
DATABASE_SSLMODE=require

# ── LLM provider selection ────────────────────────────────────────────────────
# ollama (default) | huggingface | openai | gemini | stub
FIRASA_LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────────────────
FIRASA_OLLAMA_HOST=http://localhost:11434
FIRASA_LLM_MODEL=qwen3:8b

# ── Hugging Face Inference API ────────────────────────────────────────────────
# Free tier: Qwen2.5-7B-Instruct, rate-limited. No API key needed for public models.
# Set FIRASA_LLM_PROVIDER=huggingface to use this.
FIRASA_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
FIRASA_HF_TOKEN=

# ── OpenAI or OpenAI-Compatible API ───────────────────────────────────────────
# Set FIRASA_LLM_PROVIDER=openai to use this.
# Works with: OpenAI, Groq, OpenRouter, Together AI, and any OpenAI-compatible endpoint.
#
# ─── OpenAI (paid) ──────────────────────────────────────────────────────
# FIRASA_OPENAI_API_KEY=sk-your-openai-key
# FIRASA_OPENAI_API_BASE=https://api.openai.com/v1
# FIRASA_OPENAI_MODEL=gpt-4o-mini
#
# ─── Groq (free tier: 30 RPM, 1K requests/day) ─────────────────────────
# FIRASA_OPENAI_API_KEY=gsk_your_groq_api_key
# FIRASA_OPENAI_API_BASE=https://api.groq.com/openai/v1
# FIRASA_OPENAI_MODEL=llama-3.3-70b-versatile
#
# ─── OpenRouter (free models available) ─────────────────────────────────
# FIRASA_OPENAI_API_KEY=sk-or-v1-your-openrouter-key
# FIRASA_OPENAI_API_BASE=https://openrouter.ai/api/v1
# FIRASA_OPENAI_MODEL=google/gemini-2.0-flash-001
#
# ─── Together AI ────────────────────────────────────────────────────────
# FIRASA_OPENAI_API_KEY=your-together-key
# FIRASA_OPENAI_API_BASE=https://api.together.xyz/v1
# FIRASA_OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
FIRASA_OPENAI_API_KEY=
FIRASA_OPENAI_API_BASE=https://api.openai.com/v1
FIRASA_OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (free tier: gemini-2.0-flash, 15 RPM, 1M tokens/day) ───────
# Get an API key at https://aistudio.google.com/apikey
# Set FIRASA_LLM_PROVIDER=gemini to use this.
FIRASA_GEMINI_API_KEY=
FIRASA_GEMINI_MODEL=gemini-2.0-flash

# ── Common ────────────────────────────────────────────────────────────────────
FIRASA_LLM_TIMEOUT=30
# FIRASA_DEBUG=true enables the ad-hoc /api/audit endpoint (dev only)
FIRASA_DEBUG=false
