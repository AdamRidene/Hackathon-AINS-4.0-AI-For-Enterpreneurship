# --- LLM provider selection -------------------------------------------------
# ollama (default) | huggingface | stub
FIRASA_LLM_PROVIDER=ollama

# --- Ollama (local) ---------------------------------------------------------
FIRASA_OLLAMA_HOST=http://localhost:11434
FIRASA_LLM_MODEL=qwen3:8b

# --- Hugging Face Inference API (toggle) ------------------------------------
# Set FIRASA_LLM_PROVIDER=huggingface to use these.
FIRASA_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
FIRASA_HF_TOKEN=

# --- Common -----------------------------------------------------------------
FIRASA_LLM_TIMEOUT=30
# Any provider falls back to a deterministic rubric/template on error, so the
# pipeline runs end-to-end even with no model installed.
