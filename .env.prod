# ── Firasa: Production Environment ──────────────────────────────────────────
# Production deployment with Neon serverless PostgreSQL and Gemini LLM.
FIRASA_ENV=prod
FIRASA_AUTH_MODE=local
FIRASA_LLM_PROVIDER=gemini

# Database — SQLite database
DATABASE_URL=sqlite:///app/_data/local.db

# LLM — Google Gemini free tier (gemini-2.0-flash: 15 RPM, 1M tokens/day)
FIRASA_GEMINI_API_KEY=your-prod-gemini-key
FIRASA_GEMINI_MODEL=gemini-2.0-flash

FIRASA_LLM_TIMEOUT=30
FIRASA_DEBUG=false
