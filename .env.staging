# ── Firasa: Staging Environment ─────────────────────────────────────────────
# Pre-production testing with real database and LLM endpoints.
FIRASA_ENV=staging
FIRASA_AUTH_MODE=local
FIRASA_LLM_PROVIDER=gemini

# Database — use Neon serverless PostgreSQL (recommended) or Supabase Postgres
# Neon:
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# Supabase:
DATABASE_URL=postgresql://postgres:password@db.your-staging-project.supabase.co:5432/postgres
DATABASE_SSLMODE=require

# Neo4j graph (optional)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# LLM — Google Gemini free tier (gemini-2.0-flash: 15 RPM, 1M tokens/day)
FIRASA_GEMINI_API_KEY=your-staging-gemini-key
FIRASA_GEMINI_MODEL=gemini-2.0-flash

FIRASA_LLM_TIMEOUT=30
FIRASA_DEBUG=false
