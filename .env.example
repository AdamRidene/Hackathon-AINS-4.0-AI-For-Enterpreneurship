# ── Firasa — Environment template ─────────────────────────────────────────────
# Copy to .env (repo root) and fill in real values. .env is gitignored.
# Backend reads the root .env (see backend/app/config.py). For the frontend
# (Vite), copy the VITE_* section into frontend/.env only if you need overrides.

# ── Auth ──────────────────────────────────────────────────────────────────────
# local (default) = PBKDF2 + session tokens.   none = no auth (dev only).
FIRASA_AUTH_MODE=local
# Comma-separated list of allowed origins (e.g. for FastAPI CORSMiddleware)
CORS_ORIGINS=https://firasa.yourdomain.com,http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (default). firasa.db holds existing accounts.
DATABASE_URL=sqlite:///app/_data/firasa.db
# Set FIRASA_SKIP_DB=true to run fully in-memory (no DB file).
FIRASA_SKIP_DB=false

# ── LLM provider ──────────────────────────────────────────────────────────────
# ollama | huggingface | openai | groq | deepseek | gemini | stub
FIRASA_LLM_PROVIDER=stub

# OpenAI-compatible providers
FIRASA_OPENAI_API_KEY=
FIRASA_OPENAI_API_BASE=https://api.openai.com/v1
FIRASA_OPENAI_MODEL=gpt-4o-mini

# Groq (OpenAI-compatible endpoint at api.groq.com/openai/v1)
FIRASA_GROQ_API_KEY=
FIRASA_GROQ_API_BASE=https://api.groq.com/openai/v1
# Safer default for answer-only chat. If you want a stronger model, try
# mixtral-8x7b-32768 or qwen/qwen3.6-27b, but qwen-style models may emit
# reasoning traces.
FIRASA_GROQ_MODEL=llama-3.1-8b-instant

# DeepSeek (OpenAI-compatible endpoint at api.deepseek.com)
FIRASA_DEEPSEEK_API_KEY=
FIRASA_DEEPSEEK_MODEL=deepseek-chat
FIRASA_LLM_TIMEOUT=60

# Cohere embeddings (optional — enables semantic RAG over the TF-IDF fallback)
FIRASA_COHERE_API_KEY=
FIRASA_COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0

# Other providers (optional — uncomment + fill if you switch FIRASA_LLM_PROVIDER)
# FIRASA_GEMINI_API_KEY=
# FIRASA_GEMINI_MODEL=gemini-2.0-flash
# FIRASA_OLLAMA_HOST=http://localhost:11434
# FIRASA_LLM_MODEL=qwen3:8b

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails always granted the "pro" plan.
ADMIN_EMAILS=

# ── Frontend (Vite) — copy to frontend/.env if overriding defaults ────────────
# VITE_API_BASE=        # empty = same-origin
# VITE_AUTH_MODE=local
