# --- LLM API Keys ------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# --- LLM Provider Selection --------------------------------------------------
# deepseek | openai | ollama | huggingface | stub
FIRASA_LLM_PROVIDER=deepseek

# --- DeepSeek ----------------------------------------------------------------
FIRASA_DEEPSEEK_API_KEY=your_deepseek_api_key_here
FIRASA_DEEPSEEK_MODEL=deepseek-v4-flash

# --- OpenAI or OpenAI-Compatible API (OpenRouter, Groq, Gemini API) ---------
# Set FIRASA_LLM_PROVIDER=openai to use these.
FIRASA_OPENAI_API_KEY=
FIRASA_OPENAI_API_BASE=https://api.openai.com/v1
FIRASA_OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local) ----------------------------------------------------------
FIRASA_OLLAMA_HOST=http://localhost:11434
FIRASA_LLM_MODEL=qwen3:8b

# --- Hugging Face Inference API ----------------------------------------------
FIRASA_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
FIRASA_HF_TOKEN=

# --- Common ------------------------------------------------------------------
FIRASA_LLM_TIMEOUT=60

# --- Database ----------------------------------------------------------------
# Neon PostgreSQL — replaces local SQLite when set
# Leave blank to use local SQLite (default)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Admin -------------------------------------------------------------------
# Comma-separated emails — always get "pro" plan, can call /api/admin/set-plan
ADMIN_EMAILS=admin@example.com
