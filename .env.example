# ── Firasa — Environment template ─────────────────────────────────────────────
# Copy to .env (repo root) and fill in real values. .env is gitignored.

# ── Auth ──────────────────────────────────────────────────────────────────────
# local (default) | supabase | none
FIRASA_AUTH_MODE=supabase
CORS_ORIGINS=https://firasa.yourdomain.com,http://localhost:5173,http://localhost:5174,http://localhost:3000

# Supabase Auth configuration (required if FIRASA_AUTH_MODE=supabase)
FIRASA_SUPABASE_URL=
FIRASA_SUPABASE_ANON_KEY=
FIRASA_SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=
FIRASA_SKIP_DB=false

# ── SMTP / Mailer ─────────────────────────────────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── LLM provider ──────────────────────────────────────────────────────────────
# ollama | huggingface | openai | groq | deepseek | gemini | stub
FIRASA_LLM_PROVIDER=stub

# OpenAI-compatible providers
FIRASA_OPENAI_API_KEY=
FIRASA_OPENAI_API_BASE=https://api.openai.com/v1
FIRASA_OPENAI_MODEL=gpt-4o-mini

# Groq
FIRASA_GROQ_API_KEY=
FIRASA_GROQ_API_BASE=https://api.groq.com/openai/v1
FIRASA_GROQ_MODEL=llama-3.1-8b-instant

# DeepSeek
FIRASA_DEEPSEEK_API_KEY=
FIRASA_DEEPSEEK_MODEL=deepseek-chat
FIRASA_LLM_TIMEOUT=60

# Cohere embeddings (optional)
FIRASA_COHERE_API_KEY=
FIRASA_COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0

# News API Configuration
FIRASA_NEWSAPI_KEY=

# ── Admin & App ──────────────────────────────────────────────────────────────
ADMIN_EMAILS=
FIRASA_APP_URL=http://localhost:5174

# ── Frontend (Vite) — copy to frontend/.env or frontend/.env.local ───────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
