# ── Firasa Frontend Environment Variables ─────────────────────────────────────
# These are Vite-prefixed env vars available at build time in the frontend.
# See backend/.env.example for backend vars.

# API base URL — empty means same-origin (nginx proxies /api to backend)
VITE_API_BASE=

# Auth mode — "local" (custom PBKDF2) or "supabase" (managed auth)
# The frontend discovers this at runtime from GET /api/auth/config,
# but you can set it here as a build-time default.
VITE_AUTH_MODE=local

# Supabase — only needed when VITE_AUTH_MODE=supabase
# Get these from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
